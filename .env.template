# Environment variables for Automation Nation deployment
# Copy this file to .env and customize the values

# Database passwords
POSTGRES_PASSWORD=automation_secure_password_change_me
REDIS_PASSWORD=redis_secure_password_change_me

# NetBox configuration
NETBOX_SECRET_KEY=netbox_secret_key_at_least_50_characters_long_change_me
NETBOX_ADMIN_PASSWORD=netbox_admin_password_change_me

# NetBox Build Options
# Set to 'true' to build NetBox from source instead of using official image
BUILD_NETBOX_FROM_SOURCE=false

# NetBox source build configuration (only used if BUILD_NETBOX_FROM_SOURCE=true)
NETBOX_VERSION=v4.1.0
NETBOX_ENABLE_PLUGINS=false
# Comma-separated list of plugins to install (if NETBOX_ENABLE_PLUGINS=true)
NETBOX_PLUGIN_LIST=netbox-topology-views,netbox-device-map,netbox-bgp
NETBOX_PLUGINS_CONFIG={}

# Override NetBox image (useful for custom builds)
# NETBOX_IMAGE=netboxcommunity/netbox:latest
# NETBOX_BUILD_CONTEXT=./netbox-build
# NETBOX_DOCKERFILE=Dockerfile.netbox

# Grafana configuration
GRAFANA_ADMIN_PASSWORD=grafana_admin_password_change_me

# GitHub API token (optional, for higher rate limits)
GITHUB_TOKEN=your_github_token_here

# Database configuration  
DATABASE_URL=postgresql://automation_user:automation_secure_password_change_me@localhost:5432/automation_nation
# For development, you can also use SQLite:
# DATABASE_URL=sqlite:///app/data/automation_nation.db
RUST_LOG=info
ENABLE_HASHING=1
ENABLE_SUDO_SUPPORT=0

# Container runtime preferences (comma-separated list)
PREFERRED_RUNTIMES=podman,docker,lxc